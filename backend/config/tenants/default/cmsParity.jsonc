{
  // Configuration profile metadata.
  "profile": "cmsParity",
  "version": 1,

  // Module switches used by Atlas navigation and backend route guards.
  "modules": {
    "governance": true,
    "finance": true,
    "inventory": true,
    "reporting": true
  },

  // Organization lifecycle policy.
  "orgLifecycle": {
    "allowedStatuses": ["pending", "approved", "active", "sunset", "archived"],
    "defaultStatus": "approved",
    "requireApprovalForCreation": false,
    "transitions": {
      "pending": ["approved", "archived"],
      "approved": ["active", "archived"],
      "active": ["sunset", "archived"],
      "sunset": ["active", "archived"],
      "archived": []
    }
  },

  // Governance document and officer term policies.
  "governance": {
    "documentLabel": "Constitution",
    "allowVersioning": true,
    "requireApprovalForDocumentPublish": false,
    "officerTermsEnabled": true,
    "documentStatuses": ["draft", "pending_review", "published", "archived"]
  },

  // Finance policy that can map to campus accounting systems.
  "finance": {
    "enabled": true,
    "workflowStates": [
      "draft",
      "submitted",
      "preliminary_review",
      "final_review",
      "changes_requested",
      "approved",
      "appealed",
      "rejected",
      "finalized"
    ],
    "transitions": {
      "draft": ["submitted"],
      "submitted": ["preliminary_review", "changes_requested"],
      "preliminary_review": ["final_review", "changes_requested", "rejected"],
      "final_review": ["approved", "changes_requested", "rejected", "appealed"],
      "changes_requested": ["submitted"],
      "approved": ["finalized", "appealed"],
      "appealed": ["final_review", "approved", "rejected"],
      "rejected": [],
      "finalized": []
    },
    "reviewActions": ["comment", "request_changes", "approve", "reject"],
    "editableStates": ["draft", "changes_requested"],
    "reviewableStates": ["submitted", "preliminary_review", "final_review", "appealed"],
    "reviewerPolicy": {
      "adminOnly": true,
      "noSelfApproval": true
    },
    "accountingDimensions": [
      {
        "key": "fund",
        "label": "Fund",
        "required": true
      },
      {
        "key": "org",
        "label": "Org",
        "required": true
      },
      {
        "key": "account",
        "label": "Account",
        "required": true,
        "values": []
      }
    ],
    "allowAppeals": true
  },

  // Inventory and assets policy.
  "inventory": {
    "enabled": true,
    "allowCheckout": true,
    "requireConditionOnReturn": true,
    "lifecycleStatuses": ["active", "maintenance", "archived"],
    "conditions": ["new", "good", "fair", "poor", "broken"]
  },

  // Reporting defaults and export types.
  "reporting": {
    "enabled": true,
    "defaultExports": ["csv", "json"],
    "scheduledReportsEnabled": true,
    "searchEntities": ["orgs", "members", "budgets", "inventory", "governance"],
    "adminSummaryCards": ["orgs", "governance", "budgets", "inventory", "exceptions"]
  },

  // Foundation for configurable admin/root permission mapping.
  "adminRoles": {
    "permissionCatalog": ["review_budget", "approve_budget", "release_budget", "manage_budget_reviewer_assignments"],
    "rootOverridesAll": true
  }
}
